<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Block all cleartext traffic for the app -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Explicit HTTPS-only for our backend and Firebase -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">lifehub-bay.vercel.app</domain>
        <domain includeSubdomains="true">lifehub.fit</domain>
        <domain includeSubdomains="true">firebaseapp.com</domain>
        <domain includeSubdomains="true">firebase.com</domain>
        <domain includeSubdomains="true">googleapis.com</domain>
        <domain includeSubdomains="true">api.revenuecat.com</domain>
    </domain-config>
</network-security-config>
