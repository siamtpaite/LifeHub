{
  "name": "lifehub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm start --prefix frontend\"",
    "backend": "npm run dev --prefix backend",
    "frontend": "npm start --prefix frontend",
    "build": "npm run build --prefix frontend",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:android": "npm run build && npx cap sync android && npx cap open android",
    "mobile:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "mobile:live": "npx cap run android --livereload --external",
    "cap:sync": "npx cap sync",
    "cap:copy": "npx cap copy",
    "cap:update": "npx cap update"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.0.0",
    "@capacitor/browser": "^8.0.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/network": "^8.0.0",
    "@capacitor/push-notifications": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@revenuecat/purchases-capacitor": "^13.2.0"
  }
}
